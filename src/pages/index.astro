    //     imageClass='h-12 w-auto md:-start-16'
    //   />
    // </Section> 
      }
      <Section title='Education'>
        <Card
          as='a'
          heading='西南石油大学'
          subheading='计算机与软件学院 | 本科'
          date='August 2022 - July 2026'
