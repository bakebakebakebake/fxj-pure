---
import { Collapse, Spoiler, Timeline } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'
import Substats from '@/components/about/Substats.astro'
import ToolSection from '@/components/about/ToolSection.astro'
import safariIcon from '@/assets/tools/app-icons/safari.png'
import pixpinIcon from '@/assets/tools/app-icons/pixpin.png'
import codexIcon from '@/assets/tools/app-icons/codex.png'
import claudeCodeIcon from '@/assets/tools/app-icons/claude-code.png'
import typelessIcon from '@/assets/tools/app-icons/typeless.png'
import antigravityIcon from '@/assets/tools/app-icons/antigravity.png'
import wechatInputIcon from '@/assets/tools/app-icons/wechat-input.png'
import doubaoIcon from '@/assets/tools/app-icons/doubao.png'
import doubaoInputIcon from '@/assets/tools/app-icons/doubao-input.png'
import notebookLmIcon from '@/assets/tools/app-icons/notebooklm-candidate.png'
import cherryStudioIcon from '@/assets/tools/app-icons/cherry-studio.png'
import raycastIcon from '@/assets/tools/app-icons/raycast.png'
import fineTuneIcon from '@/assets/tools/app-icons/fine-tune.png'
import activityWatchIcon from '@/assets/tools/app-icons/activitywatch.png'
import appleNotesIcon from '@/assets/tools/app-icons/apple-notes.png'

const headings = [
  { depth: 2, slug: 'hobbies', text: 'Hobbies' },
  { depth: 2, slug: 'tools', text: 'Tools' },
  { depth: 2, slug: 'social-networks', text: 'Social Networks' },
  { depth: 2, slug: 'gossips', text: 'Gossips' },
  { depth: 2, slug: 'about-blog', text: 'About Blog' }
]
---

<PageLayout title='About' {headings} comment>
  <p>Developer / ACMer</p>
  <p>
    一位计算机小菜鸡，正在学习中...<br /><br />
    喜欢在抽象模型、工程实现和真实问题之间来回推敲，把东西尽量想明白、写清楚。<br /><br />
    长期目标希望将算法、系统、写作和自动化工具逐步连成一套真正稳定的个人工作流。
  </p>
  <p>
    My motto: Anyway, Pace yourself. <Spoiler>不管怎样，调整好自己的节奏！</Spoiler>
  </p>
  <!-- <Button title='Sponsor Me' class='w-fit' href='/projects#sponsorship' variant='ahead' /> -->

  {/* general-talk */}
  <h2 id='hobbies'>Hobbies</h2>
  <ul>
    <li>热爱数学、算法与逻辑推理，享受探索抽象结构与底层原理。</li>
    <li>喜欢 coding、搭建个人博客，钻研各类工具。</li>
    <li>关注大模型发展方向、知识管理与自动化，追求极致的系统体验。</li>
    <li>对哲学与认知科学保持好奇，喜欢深度思考。</li>
  </ul>

  {/* tools */}
  <h2 id='tools'>Tools</h2>
  <p>日常高频使用的一组工具如下。</p>
  <ToolSection
    class='mb-5'
    title='Productivity'
    tools={[
      {
        name: 'Safari',
        description: '主力浏览器',
        href: 'https://www.apple.com/safari/',
        icon: safariIcon
      },
      {
        name: 'Chrome',
        description: '兼容性与多账号场景',
        href: 'https://www.google.com/chrome/',
        icon: import('@/assets/tools/chrome.svg?raw')
      },
      {
        name: 'Obsidian',
        description: '知识库与长线笔记',
        href: 'https://www.obsidian.md/',
        icon: import('@/assets/tools/obsidian.svg?raw')
      },
      {
        name: 'Apple Notes',
        description: '轻量速记与收集',
        href: 'https://www.apple.com/macos/notes/',
        icon: appleNotesIcon
      },
      {
        name: 'Typora',
        description: '单文件 Markdown 编辑',
        href: 'https://typora.io/',
        icon: import('@/assets/tools/typora.svg?raw')
      },
      {
        name: 'Typeless',
        description: '沉浸式写作与整理',
        href: 'https://www.typeless.com/',
        icon: typelessIcon
      },
      {
        name: 'PixPin',
        description: '截图、贴图与标注',
        href: 'https://pixpin.cn/',
        icon: pixpinIcon
      },
      {
        name: 'Raycast',
        description: '启动器与系统工作流',
        href: 'https://www.raycast.com/',
        icon: raycastIcon
      },
      {
        name: '微信输入法',
        description: '中文输入',
        href: 'https://z.weixin.qq.com/',
        icon: wechatInputIcon
      },
      {
        name: '豆包输入法',
        description: '语音输入',
        href: 'https://www.doubao.com/',
        icon: doubaoInputIcon
      }
    ]}
  />
  <ToolSection
    class='mb-5'
    title='Development'
    tools={[
      {
        name: 'Codex',
        description: '代码代理',
        href: 'https://openai.com/codex/',
        icon: codexIcon
      },
      {
        name: 'Claude Code',
        description: '终端代码代理',
        href: 'https://claude.com/product/claude-code',
        icon: claudeCodeIcon
      },
      {
        name: 'tmux',
        description: '终端会话管理',
        href: 'https://github.com/tmux/tmux',
        icon: import('@/assets/tools/tmux.svg?raw')
      },
      {
        name: 'Antigravity',
        description: 'Agentic coding workspace',
        href: 'https://antigravity.google/',
        icon: antigravityIcon
      }
    ]}
  />
  <ToolSection
    class='mb-5'
    title='AI & Automation'
    tools={[
      {
        name: 'Doubao',
        description: '中文 AI 助手',
        href: 'https://www.doubao.com/',
        icon: doubaoIcon
      },
      {
        name: 'NotebookLM',
        description: '资料驱动的问答与整理',
        href: 'https://notebooklm.google.com/',
        icon: notebookLmIcon
      },
      {
        name: 'Cherry Studio',
        description: '多模型桌面工作台',
        href: 'https://cherry-ai.com/',
        icon: cherryStudioIcon
      },
      {
        name: 'ActivityWatch',
        description: '时间追踪与行为统计',
        href: 'https://activitywatch.net/',
        icon: activityWatchIcon
      }
    ]}
  />
  <ToolSection
    class='mb-5'
    title='Environment'
    tools={[
      {
        name: 'MacOS Tahoe',
        description: 'MacBook Air',
        href: 'https://www.apple.com/macos/',
        icon: import('@/assets/tools/apple.svg?raw')
      },
      {
        name: 'Windows 11 Pro Workstation 24H2',
        description: 'Lenovo Legion',
        href: 'https://news.microsoft.com/windows11-general-availability/',
        icon: import('@/assets/tools/windows11.svg?raw')
      },
      {
        name: 'Ubuntu 22.04 LTS',
        description: 'Linux 发行版（WSL）',
        href: 'https://ubuntu.com/',
        icon: import('@/assets/tools/ubuntu.svg?raw')
      }
    ]}
  />
  <ToolSection
    class='mb-5'
    title='Other'
    tools={[
      {
        name: 'FineTune',
        description: '按应用控制音量',
        href: 'https://github.com/ronitsingh10/FineTune',
        icon: fineTuneIcon
      }
    ]}
  />

  {/* social-networks */}
  <h2 id='social-networks'>Social Networks</h2>
  <Substats
    stats={[
      {
        platform: 'GitHub',
        icon: 'github',
        link: 'https://github.com/bakebakebakebake',
        text: 'profile',
        badge: 'Profile'
      },
      {
        platform: 'Zhihu',
        icon: 'zhihu',
        color: '#1677ff',
        link: 'https://www.zhihu.com/people/4-95-22-83',
        text: 'profile',
        badge: 'Profile'
      },
      {
        platform: 'Bilibili',
        icon: 'bilibili',
        color: '#00a1d6',
        link: 'https://space.bilibili.com/2071277173',
        text: 'profile',
        badge: 'Profile'
      },
      {
        platform: 'X',
        icon: 'x',
        link: 'https://x.com/fxj_go/likes',
        text: 'profile',
        badge: 'Profile'
      }
    ]}
  />

  {/* gossips */}
  <h2 id='gossips'>Gossips</h2>
  <Collapse title='随便聊聊'>
    这里是一些关于我的小八卦、碎碎念或者日常感想。<br />
    也许是最近喜欢的书、电影，或者是一些有趣的生活琐事。<br />
    你有什么想知道的，也可以留言告诉我哦！
  </Collapse>

  {/* about-blog */}
  <h2 id='about-blog'>About Blog</h2>
  <p>Write history:</p>
  <Timeline
    events={[
      {
        date: '2023-03-13',
        content: 'Started writing Markdown notes in Youdao Note'
      },
      {
        date: '2023-10-23',
        content: 'Started writing notes on Luogu'
      },
      {
        date: '2024-01-10',
        content: 'Built my first Hexo blog'
      },
      {
        date: '2024-01-12',
        content: 'Tried to build a digital garden'
      },
      {
        date: '2025-10-06',
        content: 'Started this Astro blog'
      }
    ]}
  />
  <p>
    The smooth operation and personalized customization of website also rely on the resources and
    technical support provided by the following excellent projects/service providers:
  </p>
  <ul>
    <li>Domain: <a href='#' target='_blank'>Vercel</a></li>
    <li>
      Framework & Theme: <a href='https://astro.build/' target='_blank'>Astro</a> + <a
        href='https://github.com/cworld1/astro-theme-pure'
        target='_blank'>Astro Theme Pure</a
      >
    </li>
    <li>
      Site hosting: <a href='https://vercel.com/' target='_blank'>Vercel</a>
    </li>
    <li>
      CI/CD: <a href='https://vercel.com/workflow' target='_blank'>Vercel Workflow</a>
    </li>
    <!-- <li>Resources speedup: <a href='https://cdn.cbd.int/' target='_blank'>CBD CDN</a></li> -->
    <li>Comment system: <a href='https://waline.js.org' target='_blank'>Waline</a></li>
    <li>
      Visits: <a href='https://supabase.com/' target='_blank'>Supabase</a> +
      <a href='https://waline.js.org/' target='_blank'>Waline</a>
    </li>
    <li>
      Other statistics: <a href='https://github.com/spencerwooo/substats' target='_blank'
        >Substats</a
      >
    </li>
  </ul>
</PageLayout>
