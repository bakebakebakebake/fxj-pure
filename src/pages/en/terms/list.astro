---
import { Button, CardList } from 'astro-pure/user'
import { cn } from 'astro-pure/utils'
import PageLayout from '@/layouts/BaseLayout.astro'
import { integ, terms } from '@/site-config'

const meta = {
  title: 'Site Policy',
  description: 'Site policy documentation'
}
---

<PageLayout {meta}>
  <Button title='Back' href='/en' variant='back' />
  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate'>
      <h1 class='mb-6 text-3xl font-medium'>Site Policy</h1>
    </div>

    <div id='content' class={cn('animate mt-8 max-w-none md:min-w-[45ch]', integ.typography.class)}>
      <h2 class='text-xl font-medium'>Site policy documentation</h2>
      <CardList
        title='Terms content'
        list={terms.list.map((item) => ({
          ...item,
          link: `/en${item.link}`
        }))}
      />
      <h2 class='text-xl font-medium'>Note</h2>
      <p>English policy pages are currently lightweight mirrors so the route structure is ready.</p>
    </div>
  </main>
</PageLayout>
