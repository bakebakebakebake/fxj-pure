---
import { Button } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
---

<PageLayout meta={{ title: 'Disclaimer', description: 'English placeholder for disclaimer' }}>
  <Button title='Back' href='/en/terms/list' variant='back' />
  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate'>
      <h1 class='mb-6 text-3xl font-medium'>Disclaimer</h1>
    </div>
    <div id='content' class='animate'>
      <p>The English disclaimer is being prepared.</p>
      <p>You can read the current Chinese version here: <a href='/terms/disclaimer'>/terms/disclaimer</a>.</p>
    </div>
  </main>
</PageLayout>
