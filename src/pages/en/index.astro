---
import { Image } from 'astro:assets'

import { Button, Card, Icon, Label } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import LocalizedPostPreview from '@/components/pages/LocalizedPostPreview.astro'
import ProjectCard from '@/components/home/ProjectCard.astro'
import Section from '@/components/home/Section.astro'
import avatar from '@/assets/IMG_1052.jpeg'
import { getLocalizedBlogPreviews, sortLocalizedBlogByDate } from '@/utils/blog'

const MAX_POSTS = 10
const allPostsByDate = sortLocalizedBlogByDate(await getLocalizedBlogPreviews('en')).slice(0, MAX_POSTS)
const rssUrl = Astro.site ? new URL('/en/rss.xml', Astro.site).toString() : '/en/rss.xml'
---

<PageLayout meta={{ title: 'Home', description: 'FXJ Wiki in English' }} highlightColor='#659EB9'>
  <main class='flex w-full flex-col items-center'>
    <section class='animate mb-10 flex flex-col items-center gap-y-7' id='content-header'>
      <Image
        src={avatar}
        alt='profile'
        class='h-28 w-auto rounded-full border p-1'
        loading='eager'
      />

      <div class='flex flex-col items-center gap-y-4 text-center'>
        <h1 class='text-3xl font-bold'>MakkaPakka</h1>
        <div class='flex flex-wrap justify-center gap-x-5 gap-y-3'>
          <Label title='China'>
            <Icon name='location' class='size-5' slot='icon' />
          </Label>
          <Label
            title='Source code'
            as='a'
            href='https://github.com/bakebakebakebake/fxj-pure'
            target='_blank'
          >
            <Icon name='github' class='size-5' slot='icon' />
          </Label>
          <Label title='RSS' as='a' href={rssUrl} target='_blank'>
            <Icon name='rss' class='size-5' slot='icon' />
          </Label>
        </div>
      </div>
    </section>

    <div id='content' class='animate flex flex-col gap-y-10 md:w-4/5 lg:w-5/6'>
      <Section title='About'>
        <p class='text-muted-foreground'>Developer / ACMer</p>
        <p class='text-muted-foreground'>
          Just a computer noob, still learning...<br /><br />
        </p>
        <Button title='More about me' class='w-fit self-end' href='/en/about' variant='ahead' />
      </Section>

      {
        allPostsByDate.length > 0 && (
          <Section title='Posts'>
            <ul class='flex flex-col gap-y-1.5 sm:gap-y-2'>
              {allPostsByDate.map((post) => (
                <LocalizedPostPreview post={post} href={`/en/blog/${post.id}`} showDescription={false} />
              ))}
            </ul>
            <Button title='More posts' class='w-fit self-end' href='/en/blog' variant='ahead' />
          </Section>
        )
      }

      <Section title='Education'>
        <Card
          as='a'
          heading='Southwest Petroleum University'
          subheading='School of Computer Science and Software Engineering | B.Eng.'
          date='August 2022 - July 2026'
          href='https://www.swpu.edu.cn/'
        />
      </Section>

      <Section title='Website List'>
        <div class='grid grid-cols-1 gap-3 sm:grid-cols-2'>
          <ProjectCard
            href='https://waline.fxj.wiki/ui/login'
            heading='Waline'
            subheading='Comment system backend and pageview service.'
            imagePath='/src/assets/projects/wen-qiao-g_w8I64FiO0-unsplash.jpg'
          />
          <ProjectCard
            href='https://status.fxj.wiki'
            heading='Status'
            subheading='Public uptime page for availability, incidents, and recovery.'
            imagePath='/src/assets/projects/alex-tyson-2BAXJ7ha74s-unsplash.jpg'
          />
          <ProjectCard
            href='https://onedrive.fxj.wiki'
            heading='OneDrive Share'
            subheading='OneDrive file listing, preview, and download portal.'
            imagePath='/src/assets/projects/angelica-teran-Bk9hpaXHK4o-unsplash.jpg'
          />
        </div>
        <div
          class='my-4 select-none rounded-xl border px-3 opacity-75 sm:px-4'
          aria-disabled='true'
          title='Archived sites are unavailable'
        >
          <div class='flex cursor-not-allowed items-center justify-between py-1.5 sm:py-2'>
            <p class='m-0'>Archived Sites</p>
            <div class='expand-button'>
              <svg
                xmlns='http://www.w3.org/2000/svg'
                width='16'
                height='16'
                viewBox='0 0 24 24'
                fill='none'
                stroke-width='2.5'
                stroke-linecap='round'
                stroke-linejoin='round'
                class='my-1 stroke-muted-foreground'
              >
                <line x1='5' y1='12' x2='19' y2='12'></line>
                <polyline points='12 5 19 12 12 19'></polyline>
              </svg>
            </div>
          </div>
        </div>
      </Section>

      <!-- <Section title='Skills'>
        <SkillLayout title='Languages' skills={languageSkills} />
        <SkillLayout title='Backend' skills={backendSkills} />
        <SkillLayout title='Computer Science' skills={csBasics} />
      </Section> -->
    </div>
  </main>
</PageLayout>
