---
import { Timeline } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'
import Substats from '@/components/about/Substats.astro'
import ToolSection from '@/components/about/ToolSection.astro'
import safariIcon from '@/assets/tools/app-icons/safari.png'
import pixpinIcon from '@/assets/tools/app-icons/pixpin.png'
import codexIcon from '@/assets/tools/app-icons/codex.png'
import claudeCodeIcon from '@/assets/tools/app-icons/claude-code.png'
import typelessIcon from '@/assets/tools/app-icons/typeless.png'
import antigravityIcon from '@/assets/tools/app-icons/antigravity.png'
import wechatInputIcon from '@/assets/tools/app-icons/wechat-input.png'
import doubaoIcon from '@/assets/tools/app-icons/doubao.png'
import doubaoInputIcon from '@/assets/tools/app-icons/doubao-input.png'
import notebookLmIcon from '@/assets/tools/app-icons/notebooklm-candidate.png'
import cherryStudioIcon from '@/assets/tools/app-icons/cherry-studio.png'
import raycastIcon from '@/assets/tools/app-icons/raycast.png'
import fineTuneIcon from '@/assets/tools/app-icons/fine-tune.png'
import activityWatchIcon from '@/assets/tools/app-icons/activitywatch.png'
import appleNotesIcon from '@/assets/tools/app-icons/apple-notes.png'

const headings = [
  { depth: 2, slug: 'hobbies', text: 'Hobbies' },
  { depth: 2, slug: 'tools', text: 'Tools' },
  { depth: 2, slug: 'social-networks', text: 'Social Networks' },
  { depth: 2, slug: 'about-blog', text: 'About Blog' }
]
---

<PageLayout title='About' {headings} comment>
  <p>Developer / ACMer</p>
  <p>
    Just a computer noob, still learning...<br /><br />
    I like moving back and forth between abstract models, practical implementation, and real
    problems, trying to understand things clearly enough to write them down.<br /><br />
    My long-term goal is to gradually connect algorithms, systems, writing, and automation into a
    truly stable personal workflow.
  </p>

  <h2 id='hobbies'>Hobbies</h2>
  <ul>
    <li>I enjoy mathematics, algorithms, and logical reasoning, especially abstract structures and low-level principles.</li>
    <li>I like coding, building my personal blog, and tinkering with all kinds of tools.</li>
    <li>I pay close attention to LLMs, knowledge management, and automation, and I care about polished systems.</li>
    <li>I stay curious about philosophy and cognitive science, and enjoy thinking deeply.</li>
  </ul>

  <h2 id='tools'>Tools</h2>
  <ToolSection
    class='mb-5'
    title='Productivity'
    tools={[
      { name: 'Safari', description: 'Primary browser', href: 'https://www.apple.com/safari/', icon: safariIcon },
      { name: 'Chrome', description: 'Compatibility and multi-account flows', href: 'https://www.google.com/chrome/', icon: import('@/assets/tools/chrome.svg?raw') },
      { name: 'Obsidian', description: 'Knowledge base and long-term notes', href: 'https://obsidian.md/', icon: import('@/assets/tools/obsidian.svg?raw') },
      { name: 'Apple Notes', description: 'Quick capture and lightweight notes', href: 'https://www.apple.com/macos/notes/', icon: appleNotesIcon },
      { name: 'Typora', description: 'Single-file Markdown editor', href: 'https://typora.io/', icon: import('@/assets/tools/typora.svg?raw') },
      { name: 'Typeless', description: 'Focused writing and organization', href: 'https://www.typeless.com/', icon: typelessIcon },
      { name: 'PixPin', description: 'Screenshots, pinning, and annotation', href: 'https://pixpin.cn/', icon: pixpinIcon },
      { name: 'Raycast', description: 'Launcher and system workflows', href: 'https://www.raycast.com/', icon: raycastIcon },
      { name: 'WeChat Input', description: 'Chinese input method', href: 'https://z.weixin.qq.com/', icon: wechatInputIcon },
      { name: 'Doubao Input', description: 'Voice input', href: 'https://www.doubao.com/', icon: doubaoInputIcon }
    ]}
  />
  <ToolSection
    class='mb-5'
    title='Development'
    tools={[
      { name: 'Codex', description: 'Coding agent', href: 'https://openai.com/codex/', icon: codexIcon },
      { name: 'Claude Code', description: 'Terminal coding agent', href: 'https://claude.com/product/claude-code', icon: claudeCodeIcon },
      { name: 'tmux', description: 'Terminal session management', href: 'https://github.com/tmux/tmux', icon: import('@/assets/tools/tmux.svg?raw') },
      { name: 'Antigravity', description: 'Agentic coding workspace', href: 'https://antigravity.google/', icon: antigravityIcon }
    ]}
  />
  <ToolSection
    class='mb-5'
    title='AI & Automation'
    tools={[
      { name: 'Doubao', description: 'Chinese AI assistant', href: 'https://www.doubao.com/', icon: doubaoIcon },
      { name: 'NotebookLM', description: 'Source-grounded research companion', href: 'https://notebooklm.google.com/', icon: notebookLmIcon },
      { name: 'Cherry Studio', description: 'Desktop multi-model workspace', href: 'https://cherry-ai.com/', icon: cherryStudioIcon },
      { name: 'ActivityWatch', description: 'Time tracking and personal analytics', href: 'https://activitywatch.net/', icon: activityWatchIcon }
    ]}
  />
  <ToolSection
    class='mb-5'
    title='Environment'
    tools={[
      { name: 'macOS', description: 'MacBook Air', href: 'https://www.apple.com/macos/', icon: import('@/assets/tools/apple.svg?raw') },
      { name: 'Windows 11', description: 'Lenovo Legion', href: 'https://www.microsoft.com/windows/windows-11', icon: import('@/assets/tools/windows11.svg?raw') },
      { name: 'Ubuntu (WSL)', description: 'Linux distribution', href: 'https://ubuntu.com/', icon: import('@/assets/tools/ubuntu.svg?raw') }
    ]}
  />
  <ToolSection
    class='mb-5'
    title='Other'
    tools={[
      { name: 'FineTune', description: 'Per-app volume control', href: 'https://github.com/ronitsingh10/FineTune', icon: fineTuneIcon }
    ]}
  />

  <h2 id='social-networks'>Social Networks</h2>
  <Substats
    stats={[
      {
        platform: 'GitHub',
        icon: 'github',
        link: 'https://github.com/bakebakebakebake',
        text: 'profile',
        badge: 'Profile'
      },
      {
        platform: 'Zhihu',
        icon: 'zhihu',
        color: '#1677ff',
        link: 'https://www.zhihu.com/people/4-95-22-83',
        text: 'profile',
        badge: 'Profile'
      },
      {
        platform: 'Bilibili',
        icon: 'bilibili',
        color: '#00a1d6',
        link: 'https://space.bilibili.com/2071277173',
        text: 'profile',
        badge: 'Profile'
      },
      {
        platform: 'X',
        icon: 'x',
        link: 'https://x.com/fxj_go/likes',
        text: 'profile',
        badge: 'Profile'
      }
    ]}
  />

  <h2 id='about-blog'>About Blog</h2>
  <Timeline
    events={[
      { date: '2023-03-13', content: 'Started writing Markdown notes in Youdao Note' },
      { date: '2023-10-23', content: 'Started writing notes on Luogu' },
      { date: '2024-01-10', content: 'Built my first Hexo blog' },
      { date: '2025-10-06', content: 'Moved into the current Astro-based FXJ Wiki' }
    ]}
  />
</PageLayout>
