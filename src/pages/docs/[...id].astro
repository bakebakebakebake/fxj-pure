---
import { render, type CollectionEntry } from 'astro:content'

import { MediumZoom } from 'astro-pure/advanced'
import { getBlogCollection } from 'astro-pure/server'
import { Icon } from 'astro-pure/user'
import PageLayout from '@/layouts/ContentLayout.astro'
import DocsContents from '@/components/docs/DocsContents.astro'
import TOC from '@/components/pages/TOC.astro'
import { docsSourceMeta, getDocsSiblings } from '@/utils/docs'

export const prerender = true

export async function getStaticPaths() {
  const posts = (await getBlogCollection('docs')) as CollectionEntry<'docs'>[]

  return posts.map((post) => ({
    params: { id: post.id },
    props: { post }
  }))
}

const { post } = Astro.props
const docsCollection = (await getBlogCollection('docs')) as CollectionEntry<'docs'>[]
const { Content, headings } = await render(post)
const { description, title } = post.data
const { prev, next } = getDocsSiblings(docsCollection, post)
const hasArticleToc = headings.some(({ depth }) => depth > 1)
const currentSource = docsSourceMeta.find((source) => source.key === post.data.source)
const seriesTitle = currentSource?.title.zh ?? '当前系列'
---

<PageLayout meta={{ description, title }} back='/docs'>
  <Fragment slot='sidebar'>
    {
      hasArticleToc ? (
        <TOC headings={headings} title='文章目录' class='block mt-3' />
      ) : (
        <DocsContents class='block mt-3' />
      )
    }
  </Fragment>

  <Fragment slot='header'>
    <h1 class='text-2xl font-medium sm:mb-2 sm:text-3xl'>
      {title}
    </h1>
    <div class='mt-4 flex flex-wrap gap-x-4 gap-y-2 text-xs leading-6 text-muted-foreground'>
      {
        // Description
        description && (
          <blockquote class='text-sm italic text-muted-foreground'>
            <q>{description}</q>
          </blockquote>
        )
      }
    </div>
    {

        /* Show more docs collapse on small screen */
        // <Collapse class='md:hidden' title='See more docs'>
        //   <DocsContents title={false} />
        // </Collapse>
    }
  </Fragment>

  <Content />

  <div slot='bottom'>
    <h2 class='mb-3 text-sm font-medium text-foreground'>继续阅读</h2>
    <div class='mt-3 grid gap-2 sm:mt-6 sm:grid-cols-[minmax(0,1fr)_auto_minmax(0,1fr)] sm:items-center'>
      <div class='min-w-0'>
        {
          prev && (
            <a
              href={`/docs/${prev.id}`}
              class='inline-flex max-w-full items-center gap-2 rounded-xl px-4 py-2 no-underline transition-colors hover:bg-muted'
            >
              <span class='truncate'>← {prev.data.title}</span>
            </a>
          )
        }
      </div>
      <a
        href='/docs'
        class='inline-flex w-fit shrink-0 items-center justify-center gap-2 self-start whitespace-nowrap rounded-full border border-border bg-muted/60 px-4 py-2 text-sm text-foreground no-underline transition-colors hover:bg-muted sm:self-auto'
      >
        <Icon name='list' class='size-4 shrink-0' />
        <span class='sm:hidden'>返回 Docs</span>
        <span class='hidden sm:inline'>返回文档首页</span>
      </a>
      <div class='min-w-0 text-end'>
        {
          next && (
            <a
              href={`/docs/${next.id}`}
              class='inline-flex max-w-full items-center gap-2 rounded-xl px-4 py-2 no-underline transition-colors hover:bg-muted'
            >
              <span class='truncate'>{next.data.title} →</span>
            </a>
          )
        }
      </div>
    </div>

    <div class='mt-6 rounded-2xl border border-border bg-muted/30 px-4 py-4 sm:px-5 sm:py-5'>
      <div class='mb-3'>
        <h3 class='text-sm font-medium text-foreground'>本系列目录</h3>
        <p class='mt-1 text-xs text-muted-foreground'>{seriesTitle}</p>
      </div>
      <DocsContents title={false} sourceKey={post.data.source} showSourceHeading={false} />
    </div>
  </div>
</PageLayout>
<MediumZoom />
