---
import type { MarkdownHeading } from 'astro'
import { Image } from 'astro:assets'

import { MediumZoom } from 'astro-pure/advanced'
import { Button, FormattedDate, Icon } from 'astro-pure/user'
import TOC from '@/components/pages/TOC.astro'
import PageLayout from '@/layouts/ContentLayout.astro'
import { integ } from '@/site-config'
import type { LocalizedBlogPreview } from '@/utils/blog'
import { resolveHeroImage, resolveHeroImageColor, resolveHeroImageSrc } from '@/utils/hero-image'
import type { Locale } from '@/utils/i18n'
import { withLocalePath } from '@/utils/i18n'

interface Props {
  preview: LocalizedBlogPreview
  locale: Locale
  headings?: MarkdownHeading[]
  relatedPosts?: LocalizedBlogPreview[]
  placeholder?: boolean
}

const { preview, locale, headings = [], relatedPosts = [], placeholder = false } = Astro.props
const { data } = preview
const heroImage = resolveHeroImage(data)
const articleDate = (data.updatedDate ?? data.publishDate).toISOString()
const socialImage = resolveHeroImageSrc(data) ?? '/images/social-card.png'
const currentIndex = relatedPosts.findIndex((post) => post.id === preview.id)
const prevPost = currentIndex > 0 ? relatedPosts[currentIndex - 1] : undefined
const nextPost = currentIndex >= 0 ? relatedPosts[currentIndex + 1] : undefined
const backHref = withLocalePath(locale, '/blog')
---

<PageLayout
  meta={{ articleDate, description: data.description, ogImage: socialImage, title: data.title }}
  highlightColor={resolveHeroImageColor(data) ?? 'hsl(var(--primary) / 1)'}
  back={backHref}
>
  {!!headings.length && <TOC {headings} slot='sidebar' />}

  <Fragment slot='header'>
    {heroImage && (
      <div class='localized-hero-image relative mb-6'>
        {typeof heroImage.src === 'string' ? (
          <img
            src={heroImage.src}
            alt={heroImage.alt || data.title}
            class='relative z-10 mt-0 h-auto w-full max-w-[65ch] rounded-2xl object-contain'
            loading='eager'
          />
        ) : (
          <Image
            {...heroImage}
            alt={heroImage.alt || data.title}
            class='relative z-10 mt-0 h-auto w-full max-w-[65ch] rounded-2xl object-contain'
            loading='eager'
          />
        )}
      </div>
    )}

    <div class='flex flex-wrap gap-x-4 gap-y-2 text-xs leading-6 text-muted-foreground'>
      <div class='flex items-center gap-1'>
        <Icon name='calendar' class='size-5' />
        <FormattedDate class='font-sans' date={data.publishDate} />
      </div>
      {data.language && (
        <span class='flex items-center gap-1'>
          <Icon name='earth' class='size-5' />
          {data.language}
        </span>
      )}
      {!!data.tags.length && (
        <span class='flex items-center gap-1'>
          <Icon name='hashtag' class='size-5' />
          {data.tags.map((tag, index) => (
            <>
              <a
                href={withLocalePath(locale, `/tags/${tag}`)}
                class='hover:underline hover:underline-offset-4'
                data-pagefind-filter='tag'
              >
                {tag}
              </a>
              {index < data.tags.length - 1 && '/'}
            </>
          ))}
        </span>
      )}
    </div>

    <h1 class='mt-4 text-2xl font-medium sm:mb-2 sm:mt-6 sm:text-3xl'>{data.title}</h1>
    <div class='mt-3 text-sm text-muted-foreground'>
      <p class='m-0'>{data.description}</p>
      {placeholder && (
        <p class='mt-3 rounded-xl border bg-muted/60 px-4 py-3 text-sm not-italic text-foreground'>
          English version is coming soon. You can read the current Chinese version here:
          <a class='ms-2 font-medium' href={`/blog/${preview.id}`}>
            /blog/{preview.id}
          </a>
        </p>
      )}
    </div>
    <div class='mt-4 w-1/2 border-t max-md:mx-auto sm:mt-6 sm:w-1/3'></div>
  </Fragment>

  <slot />

  <Fragment slot='bottom'>
    {(prevPost || nextPost) && (
      <div class='mt-3 flex gap-2 max-sm:flex-col sm:justify-between sm:mt-6'>
        <span class='min-w-0'>
          {prevPost && (
            <a
              href={withLocalePath(locale, `/blog/${prevPost.id}`)}
              class='inline-flex max-w-full items-center gap-2 rounded-xl px-4 py-2 no-underline transition-colors hover:bg-muted'
            >
              <span class='truncate'>← {prevPost.data.title}</span>
            </a>
          )}
        </span>
        <span class='min-w-0'>
          {nextPost && (
            <a
              href={withLocalePath(locale, `/blog/${nextPost.id}`)}
              class='inline-flex max-w-full items-center gap-2 rounded-xl px-4 py-2 no-underline transition-colors hover:bg-muted'
            >
              <span class='truncate'>{nextPost.data.title} →</span>
            </a>
          )}
        </span>
      </div>
    )}
    <div class='mt-3 sm:mt-6'>
      <Button title={locale === 'en' ? 'Read in Chinese' : 'Read in English'} href={locale === 'en' ? `/blog/${preview.id}` : `/en/blog/${preview.id}`} variant='ahead' />
    </div>
  </Fragment>
</PageLayout>

{integ.mediumZoom.enable && <MediumZoom />}
