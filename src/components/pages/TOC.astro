---
import type { MarkdownHeading } from 'astro'

import TOCHeading from '@/components/pages/TOCHeading.astro'
import { generateToc } from '@/plugins/toc'

interface Props {
  headings: MarkdownHeading[]
  class?: string
  id?: string
  title?: string
}

const { headings, class: className, title = 'TABLE OF CONTENTS', ...props } = Astro.props
const toc = generateToc(headings)
---

<toc-heading class={className} {...props}>
  <h2 class='font-semibold'>{title}</h2>
  <ul class='mt-4 text-card-foreground'>
    {toc.map((heading) => <TOCHeading heading={heading} />)}
  </ul>
</toc-heading>

<script>
  interface TOCLink {
    element: HTMLAnchorElement
    progressBar: HTMLElement
    slug: string
    node: HTMLLIElement
    shell: HTMLElement
  }

  interface HeadingProgress {
    inView: boolean
    progress: number
  }

  class TOC extends HTMLElement {
    headings: HTMLElement[] = []
    tocLinks: TOCLink[] = []
    headingProgress: Record<string, HeadingProgress> = {}
    activeSlug = ''
    frame = 0

    constructor() {
      super()

      this.headings = Array.from(
        document.querySelectorAll('article h2, article h3, article h4, article h5, article h6')
      )
      this.tocLinks = Array.from(this.querySelectorAll('.toc-item')).flatMap((link) => {
        const node = link.closest('.toc-node') as HTMLLIElement | null
        if (!node) return []
        const progressBar = node.querySelector('.toc-progress') as HTMLElement | null
        const shell = node.querySelector('.toc-item-shell') as HTMLElement | null
        if (!progressBar || !shell) return []
        return {
          element: link as HTMLAnchorElement,
          progressBar,
          slug: (link.getAttribute('href') || '').substring(1),
          node,
          shell
        }
      })
    }

    getDirectChild<T extends Element>(node: Element, selector: string) {
      return Array.from(node.children).find((child) => child.matches(selector)) as T | undefined
    }

    setExpanded(node: HTMLLIElement, expanded: boolean) {
      const row = this.getDirectChild<HTMLDivElement>(node, '.toc-row')
      const toggle = row?.querySelector('.toc-toggle') as HTMLButtonElement | null
      const sublist = this.getDirectChild<HTMLUListElement>(node, '.toc-sublist') ?? null
      if (!toggle || !sublist) return

      toggle.setAttribute('aria-expanded', expanded ? 'true' : 'false')
      node.dataset.expanded = expanded ? 'true' : 'false'
      sublist.hidden = !expanded
    }

    getNodeSlug(node: HTMLLIElement) {
      return node.dataset.slug || ''
    }

    getActivePath(slug: string) {
      const activePath = new Set<string>()
      let currentNode = this.tocLinks.find((link) => link.slug === slug)?.node ?? null

      while (currentNode) {
        const currentSlug = this.getNodeSlug(currentNode)
        if (currentSlug) activePath.add(currentSlug)
        currentNode = currentNode.parentElement?.closest('.toc-node') as HTMLLIElement | null
      }

      return activePath
    }

    applyExpandedState(activeSlug = '') {
      const activePath = this.getActivePath(activeSlug)

      this.querySelectorAll('.toc-node[data-has-children]').forEach((rawNode) => {
        const node = rawNode as HTMLLIElement
        const slug = this.getNodeSlug(node)
        const depth = Number(node.dataset.depth || 2)
        const userState = node.dataset.userExpanded

        const expanded =
          activePath.has(slug) || userState === 'true' || (userState !== 'false' && depth === 2)

        this.setExpanded(node, expanded)
      })
    }

    getOffsetWithinSidebar(element: HTMLElement, sidebar: HTMLElement) {
      let offsetTop = element.offsetTop
      let current = element.offsetParent as HTMLElement | null

      while (current && current !== sidebar) {
        offsetTop += current.offsetTop
        current = current.offsetParent as HTMLElement | null
      }

      return offsetTop
    }

    syncActiveLink(nextSlug: string) {
      if (!nextSlug || nextSlug === this.activeSlug) return
      this.activeSlug = nextSlug
      this.applyExpandedState(nextSlug)

      const sidebar = document.getElementById('sidebar')
      const activeLink = this.tocLinks.find((link) => link.slug === nextSlug)?.shell
      if (!sidebar || !activeLink) return

      requestAnimationFrame(() => {
        const linkTop = this.getOffsetWithinSidebar(activeLink, sidebar)
        const viewportTop = linkTop - sidebar.scrollTop
        const minTop = sidebar.clientHeight * 0.24
        const maxTop = sidebar.clientHeight * 0.42

        if (viewportTop >= minTop && viewportTop <= maxTop) return

        const desiredTop = sidebar.clientHeight * 0.34
        const nextScrollTop = linkTop - desiredTop + activeLink.offsetHeight / 2
        const maxScrollTop = Math.max(0, sidebar.scrollHeight - sidebar.clientHeight)
        const targetScrollTop = Math.max(0, Math.min(maxScrollTop, nextScrollTop))

        if (Math.abs(targetScrollTop - sidebar.scrollTop) > 4) {
          sidebar.scrollTo({ top: targetScrollTop, behavior: 'auto' })
        }
      })
    }

    updatePositionAndStyle = () => {
      const content = document.querySelector('#content') as HTMLElement | null
      const windowHeight = window.innerHeight
      const pageOffset = window.scrollY - (content?.offsetTop || 0)
      const postOffset = (content?.offsetHeight || 0) + 127
      let currentActiveSlug = ''

      this.headings.forEach((el, index) => {
        const nextHeadingTop = this.headings[index + 1]?.offsetTop || postOffset
        const range = [el.offsetTop - pageOffset, nextHeadingTop - pageOffset - el.offsetHeight]
        const progress = (windowHeight - range[0]) / (range[1] - range[0])

        this.headingProgress[el.id] = {
          inView: range[0] < windowHeight && range[1] > 0,
          progress: Math.max(0, Math.min(1, progress))
        }

        if (!currentActiveSlug && this.headingProgress[el.id]?.inView) {
          currentActiveSlug = el.id
        }
      })

      this.tocLinks.forEach(({ element, progressBar, slug, shell }, index) => {
        const progress = this.headingProgress[slug]
        if (!progress) return

        const prevInView =
          index > 0 ? this.headingProgress[this.tocLinks[index - 1]?.slug]?.inView : false
        const nextInView =
          index < this.tocLinks.length - 1
            ? this.headingProgress[this.tocLinks[index + 1]?.slug]?.inView
            : false

        element.classList.toggle('is-active', slug === currentActiveSlug)
        shell.classList.toggle('is-range-active', progress.inView)
        shell.classList.toggle('is-range-start', progress.inView && !prevInView)
        shell.classList.toggle('is-range-end', progress.inView && !nextInView)
        progressBar.classList.toggle('is-read', !progress.inView && progress.progress === 1)
        progressBar.classList.toggle('highlight-bg', progress.inView)
        progressBar.style.setProperty(
          'height',
          `${(slug === currentActiveSlug ? 1 : progress.progress) * 72}%`
        )
      })

      if (!currentActiveSlug) {
        for (let index = this.headings.length - 1; index >= 0; index -= 1) {
          const heading = this.headings[index]
          if (heading && heading.offsetTop <= window.scrollY + 160) {
            currentActiveSlug = heading.id
            break
          }
        }
      }

      if (currentActiveSlug) {
        this.syncActiveLink(currentActiveSlug)
      }
    }

    handleScroll = () => {
      if (this.frame) cancelAnimationFrame(this.frame)
      this.frame = requestAnimationFrame(() => this.updatePositionAndStyle())
    }

    connectedCallback() {
      this.applyExpandedState()

      this.addEventListener('click', (event) => {
        const button = (event.target as HTMLElement | null)?.closest(
          '.toc-toggle'
        ) as HTMLButtonElement | null
        if (!button) return

        event.preventDefault()
        event.stopPropagation()
        const node = button.closest('.toc-node') as HTMLLIElement | null
        if (!node) return
        const expanded = button.getAttribute('aria-expanded') === 'true'
        node.dataset.userExpanded = expanded ? 'false' : 'true'
        this.setExpanded(node, !expanded)
      })

      this.tocLinks.forEach((link) => {
        link.element.addEventListener('click', (event) => {
          event.preventDefault()
          const directHeading = this.headings.find((heading) => heading.id === link.slug)
          if (!directHeading) return

          history.pushState(
            null,
            directHeading.textContent || '',
            link.element.getAttribute('href')
          )
          this.applyExpandedState(link.slug)
          directHeading.scrollIntoView({ behavior: 'smooth' })
        })
      })

      this.updatePositionAndStyle()
      window.addEventListener('scroll', this.handleScroll, { passive: true })
      window.addEventListener('resize', this.handleScroll, { passive: true })
    }

    disconnectedCallback() {
      if (this.frame) cancelAnimationFrame(this.frame)
      window.removeEventListener('scroll', this.handleScroll)
      window.removeEventListener('resize', this.handleScroll)
    }
  }

  if (!customElements.get('toc-heading')) {
    customElements.define('toc-heading', TOC)
  }
</script>

<style>
  toc-heading :global(ul) {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  toc-heading :global(.toc-item) {
    display: flow-root;
  }

  toc-heading :global(.toc-node) {
    list-style: none;
  }

  toc-heading :global(.toc-row) {
    min-width: 0;
    padding-block: 0.125rem;
  }

  toc-heading :global(.toc-item-shell) {
    width: 100%;
    transition:
      background-color 0.2s ease,
      border-radius 0.2s ease;
  }

  toc-heading :global(.toc-item-shell.is-range-active) {
    background: hsl(var(--muted) / 0.72);
  }

  toc-heading :global(.toc-sublist) {
    margin: 0;
    padding: 0;
  }

  toc-heading :global(.toc-item-shell.is-range-start) {
    border-top-left-radius: 1rem;
    border-top-right-radius: 1rem;
  }

  toc-heading :global(.toc-item-shell.is-range-end) {
    border-bottom-left-radius: 1rem;
    border-bottom-right-radius: 1rem;
  }

  toc-heading :global(.toc-item-shell.is-range-start.is-range-end) {
    border-radius: 1rem;
  }

  toc-heading :global(.toc-item.is-active) {
    border-radius: inherit;
  }

  toc-heading :global(.toc-toggle[aria-expanded='true'] .toc-toggle-icon) {
    transform: rotate(90deg);
  }

  toc-heading :global(.toc-toggle-icon) {
    transition: transform 0.2s ease;
  }
</style>
