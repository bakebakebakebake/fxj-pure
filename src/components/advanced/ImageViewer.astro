---
import config from 'virtual:config'

interface Props {
  selector?: string
  background?: string
}

const { selector = config.integ.mediumZoom.selector, background = 'hsl(var(--background) / 0.92)' } =
  Astro.props
---

<script is:inline define:vars={{ selector, background }}>
  const viewerRootId = 'content-image-viewer'

  const createViewer = () => {
    const existing = document.getElementById(viewerRootId)
    if (existing) return existing

    const root = document.createElement('div')
    root.id = viewerRootId
    root.className = 'content-image-viewer'
    root.hidden = true
    root.innerHTML = `
      <div class="content-image-viewer__backdrop" data-viewer-close="true"></div>
      <div class="content-image-viewer__shell" role="dialog" aria-modal="true" aria-label="Image preview">
        <button
          type="button"
          class="content-image-viewer__close"
          aria-label="Close image preview"
          data-viewer-close="true"
        >
          ×
        </button>
        <div class="content-image-viewer__controls">
          <button type="button" class="content-image-viewer__control" aria-label="Zoom out" data-zoom-out>
            −
          </button>
          <button type="button" class="content-image-viewer__control" aria-label="Zoom in" data-zoom-in>
            +
          </button>
        </div>
        <div class="content-image-viewer__viewport">
          <img class="content-image-viewer__image" alt="" />
        </div>
      </div>
    `
    document.body.appendChild(root)
    return root
  }

  const clamp = (value, min, max) => Math.min(Math.max(value, min), max)

  const setupViewer = () => {
    const images = [...document.querySelectorAll(selector)].filter(
      (node) => node instanceof HTMLImageElement
    )
    if (!images.length) return

    const root = createViewer()
    const shell = root.querySelector('.content-image-viewer__shell')
    const viewport = root.querySelector('.content-image-viewer__viewport')
    const viewerImage = root.querySelector('.content-image-viewer__image')
    const zoomInButton = root.querySelector('[data-zoom-in]')
    const zoomOutButton = root.querySelector('[data-zoom-out]')
    if (!(viewport instanceof HTMLDivElement) || !(viewerImage instanceof HTMLImageElement)) return

    let activeImage = null
    let scale = 1
    let gestureStartScale = 1
    let startWidth = 0

    const applyScale = (nextScale) => {
      scale = clamp(nextScale, 0.75, 4)
      syncSize()
    }

    const syncSize = () => {
      if (!viewerImage.complete || !startWidth) return
      const nextWidth = Math.max(160, startWidth * scale)
      viewerImage.style.width = `${nextWidth}px`
    }

    const resetScale = () => {
      scale = 1
      gestureStartScale = 1
      startWidth = 0
      viewerImage.style.width = ''
      viewerImage.style.maxWidth = '92vw'
      viewerImage.style.maxHeight = '88vh'
    }

    const closeViewer = () => {
      if (root.hidden) return
      root.hidden = true
      root.classList.remove('is-open')
      document.body.classList.remove('image-viewer-open')
      activeImage = null
      viewerImage.removeAttribute('src')
      viewerImage.alt = ''
      viewport.scrollTo({ left: 0, top: 0, behavior: 'instant' })
      resetScale()
    }

    const openViewer = (image) => {
      activeImage = image
      resetScale()
      viewerImage.src = image.currentSrc || image.src
      viewerImage.alt = image.alt || ''
      root.hidden = false
      root.classList.add('is-open')
      document.body.classList.add('image-viewer-open')

      requestAnimationFrame(() => {
        const renderedWidth = viewerImage.getBoundingClientRect().width
        startWidth = renderedWidth || image.naturalWidth || image.width || 0
        if (!startWidth) return
        viewerImage.style.maxWidth = 'none'
        viewerImage.style.maxHeight = 'none'
        syncSize()
      })
    }

    const stepScale = (direction) => {
      if (root.hidden || !activeImage) return
      const delta = direction === 'in' ? 0.15 : -0.15
      applyScale(scale + delta)
    }

    images.forEach((image) => {
      if (!(image instanceof HTMLImageElement)) return
      if (image.dataset.viewerBound === 'true') return
      image.dataset.viewerBound = 'true'
      image.addEventListener('click', (event) => {
        event.preventDefault()
        openViewer(image)
      })
    })

    root.addEventListener('click', (event) => {
      const target = event.target
      if (!(target instanceof HTMLElement)) return
      if (target.dataset.viewerClose === 'true') {
        closeViewer()
        return
      }
      if (target === viewport || target === shell) {
        closeViewer()
      }
    })

    document.addEventListener('keydown', (event) => {
      if (root.hidden) return
      if (event.key === 'Escape') {
        event.preventDefault()
        closeViewer()
      }
    })

    viewerImage.addEventListener(
      'wheel',
      (event) => {
        if (root.hidden || !activeImage) return
        if (!event.ctrlKey && !event.metaKey) return
        event.preventDefault()
        const delta = event.deltaY < 0 ? 0.12 : -0.12
        applyScale(scale + delta)
      },
      { passive: false }
    )

    const onGestureStart = (event) => {
      if (root.hidden) return
      event.preventDefault()
      gestureStartScale = scale
    }

    const onGestureChange = (event) => {
      if (root.hidden) return
      event.preventDefault()
      scale = clamp(gestureStartScale * event.scale, 0.85, 6)
      syncSize()
    }

    root.addEventListener('gesturestart', onGestureStart)
    root.addEventListener('gesturechange', onGestureChange)
    root.addEventListener('gestureend', (event) => {
      if (root.hidden) return
      event.preventDefault()
      applyScale(scale)
    })

    zoomInButton?.addEventListener('click', () => stepScale('in'))
    zoomOutButton?.addEventListener('click', () => stepScale('out'))
  }

  const initViewer = () => {
    setupViewer()
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initViewer, { once: true })
  } else {
    initViewer()
  }

  document.addEventListener('astro:page-load', initViewer)
</script>

<style is:global define:vars={{ background }}>
  body.image-viewer-open {
    overflow: hidden;
  }

  .content-image-viewer {
    position: fixed;
    inset: 0;
    z-index: 1000;
  }

  .content-image-viewer__backdrop {
    position: absolute;
    inset: 0;
    background: var(--background);
    backdrop-filter: blur(10px);
  }

  .content-image-viewer__shell {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-rows: auto 1fr;
    height: 100%;
    width: 100%;
    place-items: center;
    padding: 2.5rem 1.25rem 1.5rem;
  }

  .content-image-viewer__close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    display: inline-flex;
    height: 2.5rem;
    width: 2.5rem;
    align-items: center;
    justify-content: center;
    border: 1px solid hsl(var(--border) / 0.9);
    border-radius: 9999px;
    background: hsl(var(--background) / 0.82);
    color: hsl(var(--foreground) / 1);
    font-size: 1.5rem;
    line-height: 1;
  }

  .content-image-viewer__controls {
    position: absolute;
    left: 1rem;
    top: 1rem;
    z-index: 2;
    display: inline-flex;
    gap: 0.5rem;
  }

  .content-image-viewer__control {
    display: inline-flex;
    height: 2.25rem;
    width: 2.25rem;
    align-items: center;
    justify-content: center;
    border: 1px solid hsl(var(--border) / 0.9);
    border-radius: 9999px;
    background: hsl(var(--background) / 0.82);
    color: hsl(var(--foreground) / 1);
    font-size: 1.4rem;
    line-height: 1;
  }

  .content-image-viewer__viewport {
    align-self: center;
    max-height: calc(100vh - 5rem);
    max-width: min(96vw, 1400px);
    overflow: auto;
    border-radius: 1.25rem;
    padding: 0.5rem;
    scrollbar-gutter: stable both-edges;
  }

  .content-image-viewer__image {
    display: block;
    margin: 0 auto;
    max-width: 92vw;
    max-height: 88vh;
    width: auto;
    height: auto;
    border-radius: 1rem;
    box-shadow: 0 24px 80px rgb(0 0 0 / 0.35);
    user-select: none;
    -webkit-user-drag: none;
  }

  @media (max-width: 640px) {
    .content-image-viewer__shell {
      padding-inline: 0.5rem;
      padding-top: 4rem;
    }

    .content-image-viewer__viewport {
      max-height: calc(100vh - 4rem);
      max-width: 100vw;
      padding: 0.25rem;
    }
  }
</style>
